{
  "name": "blogapp",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client",
    "server",
    "tests/e2e-playwright"
  ],
  "scripts": {
    "build": "npm run build --workspace @blogapp/client",
    "dev": "concurrently -n server,client -c red,blue --kill-others \"npm:dev:server\" \"npm:dev:client\"",
    "dev:tui": "node tools/dev-tui.js",
    "dev:server": "npm run dev --workspace @blogapp/server",
    "dev:client": "npm run dev --workspace @blogapp/client",
    "start": "npm run start --workspace @blogapp/server",
    "start:prod": "npm run build && npm run start",
    "lint": "npm run lint --workspaces --if-present",
    "lint:client": "npm run lint --workspace @blogapp/client",
    "lint:server": "npm run lint --workspace @blogapp/server",
    "test": "npm run test:client && npm run test:server",
    "test:server": "npm run test --workspace @blogapp/server",
    "test:client": "npm run test --workspace @blogapp/client",
    "test:e2e": "npm run test --workspace @blogapp/e2e-playwright",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.8.2"
  }
}
